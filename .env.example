# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# WebDAV Server Configuration (with VITE_ prefix for Vite)
VITE_WEBDAV_URL=https://your-webdav-server.com/path
VITE_WEBDAV_USER=your_username
VITE_WEBDAV_PASSWORD=your_password

# Push Protection Password (for local sync UI)
VITE_PUSH_PASSWORD=your_push_password

